# Firebase Web App Configuration — Project: TN-170 Attendance Tracker (tn170-attendance)
# Copy this file to .env.local and fill in values from Firebase Console:
# Project Settings > General > Your apps > Web app config

VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=tn170-attendance.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=tn170-attendance
VITE_FIREBASE_STORAGE_BUCKET=tn170-attendance.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id
