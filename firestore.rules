rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function contactUserDoc() {
      return get(/databases/$(database)/documents/contactUsers/$(request.auth.uid));
    }

    function isActiveUser() {
      return isSignedIn()
        && contactUserDoc().data.isActive == true;
    }

    function isOwner(resourceData) {
      return isSignedIn() && resourceData.ownerUid == request.auth.uid;
    }

    match /contactUsers/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow create, delete: if false;
      allow update: if isSignedIn()
        && request.auth.uid == userId
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['mustChangePassword', 'updatedAt'])
        && request.resource.data.mustChangePassword == false;
    }

    match /contactUserLookup/{capid} {
      allow read, write: if false;
    }

    match /contacts/{contactId} {
      allow read: if isActiveUser() && (
        resource.data.visibility == 'shared'
        || (resource.data.visibility == 'private' && isOwner(resource.data))
      );

      allow create: if isActiveUser()
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.visibility in ['private', 'shared'];

      allow update: if isActiveUser()
        && isOwner(resource.data)
        && request.resource.data.ownerUid == resource.data.ownerUid
        && request.resource.data.visibility in ['private', 'shared'];

      allow delete: if isActiveUser() && isOwner(resource.data);
    }
  }
}
